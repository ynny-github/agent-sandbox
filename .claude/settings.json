{
  "attribution": {
    "commit": ""
  },
  "autoMode": {
    "allow": [
      "$defaults",
      "Write(.claude/rules/*)",
      "Edit(.claude/rules/*)"
    ]
  },
  "env": {
    "GIT_AUTHOR_EMAIL": "noreply@anthropic.com",
    "GIT_AUTHOR_NAME": "Claude Code",
    "GIT_COMMITTER_EMAIL": "noreply@anthropic.com",
    "GIT_COMMITTER_NAME": "Claude Code"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "agent-sandbox hook",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "agent-sandbox hook",
            "type": "command"
          }
        ],
        "matcher": "Monitor"
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Read(~/.config/gh/**)",
      "Glob(~/.config/gh/**)",
      "Grep(~/.config/gh/**)",
      "Read(~/.ssh/**)",
      "Glob(~/.ssh/**)",
      "Grep(~/.ssh/**)",
      "Write(~/.ssh/known_hosts)",
      "Update(~/.ssh/known_hosts)",
      "Read(~/.docker/**)",
      "Glob(~/.docker/**)",
      "Grep(~/.docker/**)"
    ]
  }
}
